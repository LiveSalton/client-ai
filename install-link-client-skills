#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$SCRIPT_DIR"
SOURCE="$REPO_ROOT/skills/link-client-skills"
TARGET_DIR="$HOME/.local/bin"
TARGET="$TARGET_DIR/link-client-skills"

if [[ ! -f "$SOURCE" ]]; then
  echo "error: link-client-skills not found: $SOURCE" >&2
  exit 1
fi

mkdir -p "$TARGET_DIR"

if [[ -e "$TARGET" && ! -L "$TARGET" ]]; then
  echo "error: target exists and is not a symlink: $TARGET" >&2
  exit 1
fi

chmod +x "$SOURCE"
ln -sfn "$SOURCE" "$TARGET"

echo "Installed link-client-skills -> $SOURCE"
echo "Target: $TARGET"

case ":$PATH:" in
  *":$TARGET_DIR:"*) ;;
  *)
    echo "warning: $TARGET_DIR is not in PATH."
    echo "Add this to your shell profile if needed:"
    echo "  export PATH=\"$TARGET_DIR:\$PATH\""
    ;;
esac
